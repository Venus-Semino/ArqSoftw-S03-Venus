<div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
    <ul class="navbar-nav flex-grow-1">
        <li class="nav-item">
            <a class="nav-link text-light" asp-area="" asp-controller="Home" asp-action="Index">Inicio</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-light" asp-area="" asp-controller="Catalogo" asp-action="Index">Catálogo</a>
        </li>

        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <li class="nav-item ms-auto">
                <span class="nav-link text-muted me-2">👤 @User.Identity.Name</span>
            </li>
            <li class="nav-item">
                <a class="nav-link text-danger fw-bold" asp-area="" asp-controller="Cuenta" asp-action="Logout">Cerrar Sesión</a>
            </li>
        }
        else
        {
            <li class="nav-item ms-auto">
                <a class="nav-link fw-bold" style="color: #89b4fa !important;" asp-area="" asp-controller="Cuenta" asp-action="Login">Iniciar Sesión</a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-light" asp-area="" asp-controller="Cuenta" asp-action="Registro">Registrarse</a>
            </li>
        }
    </ul>
</div>