@{
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-4 form-container">
        <h2 class="text-center mb-4">Iniciar Sesión</h2>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger text-center">@ViewBag.Error</div>
        }

        <form asp-action="Login" method="post">
            <div class="form-floating mb-3">
                <input name="email" type="email" class="form-control" placeholder="nombre@ejemplo.com" required />
                <label>Correo Electrónico</label>
            </div>
            <div class="form-floating mb-4">
                <input name="password" type="password" class="form-control" placeholder="Contraseña" required />
                <label>Contraseña</label>
            </div>
            <button type="submit" class="btn btn-primary w-100 btn-lg custom-btn">Entrar</button>
        </form>

        <div class="text-center mt-4">
            <a asp-action="Registro" class="text-decoration-none" style="color: #89b4fa;">¿No tienes cuenta? Regístrate aquí</a>
        </div>
    </div>
</div>